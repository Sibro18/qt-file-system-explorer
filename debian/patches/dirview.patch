+
+struct StopFlag
+{
+public:
+	inline StopFlag()
+	{
+		setFlag(false);
+	}
+
+	inline void setFlag(bool flag)
+	{
+		m_flag.store(flag);
+	}
+
+	inline bool value() const
+	{
+		return m_flag.load();
+	}
+private:
+	std::atomic<bool> m_flag;
+};
