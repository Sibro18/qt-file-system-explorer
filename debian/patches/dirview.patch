diff -ruN original_dirview/utils/format_utils.cpp modified_dirview/utils/format_utils.cpp
--- original_dirview/utils/format_utils.cpp	1970-01-01 03:00:00.000000000 +0300
+++ modified_dirview/utils/format_utils.cpp	2026-06-28 02:38:12.516792037 +0300
@@ -0,0 +1,21 @@
+#include <QLocale>
+
+#include "format_utils.h"
+
+QString FormatUtils::formatSize(qint64 bytes)
+{
+	static const QLocale locale;
+	int precision = 2;
+
+	if (bytes < kKb)
+	{
+		precision = 0;
+	}
+	else if (bytes < kMb)
+	{
+		precision = 1;
+	}
+
+
+	return locale.formattedDataSize(bytes, precision, QLocale::DataSizeIecFormat);
+}
